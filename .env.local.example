# PodCraft API Keys
# Copy this file to .env.local and fill in your keys

# Core APIs
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
NEWS_API_KEY=

# Database (auto-set by Stripe Projects)
SUPABASE_DB_URL=
SUPABASE_DB_PASS=
SUPABASE_PROJECT_REF=
SUPABASE_PROJECT_URL=

# Auth (NextAuth.js)
NEXTAUTH_SECRET=          # Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Apple Sign-In (required for App Store)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Email (Resend - for magic links and notifications)
RESEND_API_KEY=

# Push Notifications (APNs)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY=                 # Base64-encoded .p8 key

# Storage (production only)
BLOB_READ_WRITE_TOKEN=

# Cron (auto-set by Vercel)
CRON_SECRET=
